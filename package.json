{
  "name": "simple-asteroids",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n wrangler,vite -c blue,green \"wrangler dev\" \"vite\"",
    "dev:lan": "concurrently -n wrangler,vite -c blue,green \"wrangler dev --ip 0.0.0.0 --port 8787\" \"vite --host 0.0.0.0 --port 5173\"",
    "check": "tsc && tsc -p tsconfig.worker.json",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "vite build && wrangler deploy"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260702.1",
    "concurrently": "^10.0.3",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "wrangler": "^4.106.0"
  },
  "dependencies": {
    "partyserver": "^0.5.8",
    "partysocket": "^1.3.0",
    "pixi.js": "^8.19.0",
    "xstate": "^5.32.3"
  }
}
